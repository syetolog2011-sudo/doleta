import os
import telebot
from telebot import types
from datetime import datetime
import pytz

# Инициализация бота. Токен берется из переменных окружения хостинга
TOKEN = os.getenv("BOT_TOKEN")
if not TOKEN:
    raise ValueError("Ошибочка! Забыл указать BOT_TOKEN в переменных окружения хостинга.")

bot = telebot.TeleBot(TOKEN)
MOSCOW_TZ = pytz.timezone("Europe/Moscow")

def get_remaining_time(target_month):
    """Вычисляет оставшееся время до 1-го числа указанного месяца по МСК."""
    now = datetime.now(MOSCOW_TZ)
    target_year = now.year
    
    # Если этот месяц в текущем году уже наступил/прошел, считаем до следующего года
    if now.month > target_month or (now.month == target_month and now.day >= 1):
        target_year += 1
            
    target_date = MOSCOW_TZ.localize(datetime(target_year, target_month, 1, 0, 0, 0))
    td = target_date - now
    
    days = td.days
    hours = td.seconds // 3600
    minutes = (td.seconds % 3600) // 60
    
    return f"⏳ **{days} дн. {hours} ч. {minutes} мин.**"

@bot.message_handler(commands=['start', 'help', 'how'])
def send_all_info(message):
    # Собираем таймеры для каждого времени года
    spring_time = get_remaining_time(3)   # Март
    summer_time = get_remaining_time(6)   # Июнь
    autumn_time = get_remaining_time(9)   # Сентябрь
    winter_time = get_remaining_time(12)  # Декабрь

    full_text = (
        "📊 **Сколько осталось до смены сезонов:**\n\n"
        "🌸 **До весны:**\n"
        f"{spring_time}\n\n"
        "☀️ **До лета:**\n"
        f"{summer_time}\n\n"
        "🍂 **До осени:**\n"
        f"{autumn_time}\n\n"
        "❄️ **До зимы:**\n"
        f"{winter_time}\n\n"
        "⚙️ _Все расчеты ведутся автоматически в реальном времени по **Московскому часовому поясу (МСК)** от 00:00 первого числа стартового месяца._"
    )
    
    bot.send_message(message.chat.id, full_text, parse_mode="Markdown")

# Настройка меню (будет показывать только одну команду)
bot.set_my_commands([
    types.BotCommand("how", "Узнать сколько осталось до всех сезонов 📅")
])

if __name__ == "__main__":
    print("Бот запущен. Доступна только команда /how...")
    bot.infinity_polling()
